# Copy to .env and fill in real values. .env is gitignored.

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Airtable Personal Access Token — https://airtable.com/create/tokens
# Required scopes:
#   data.records:read
#   data.records:write
#   schema.bases:read
#   schema.bases:write
# Required access: the base referenced by AIRTABLE_BASE_ID below.
AIRTABLE_TOKEN=pat...

# Airtable base ID (looks like "appXXXXXXXXXXXXXX").
# Find it in the URL of your base, or via https://airtable.com/api
AIRTABLE_BASE_ID=app...
